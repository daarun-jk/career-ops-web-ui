# Server Configuration

# Port the server runs on (default: 3000)
PORT=3000

# Node environment
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ── Gemini Integration (for /api/jobs/evaluate) ───────────────────
# Get a free API key at https://aistudio.google.com/apikey
# Free tier: 15 RPM / 1M tokens/day with gemini-2.5-flash (no billing needed)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override default Gemini model
# Default: gemini-flash-latest
# Alternatives: gemini-3.5-flash, gemini-3.1-flash-lite, gemini-2.5-flash, gemini-2.5-flash-lite
# GEMINI_MODEL=gemini-flash-latest

# ── Groq Integration ───────────────────────────────────────────
# Get a free API key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Override default Groq model
# Supported models: openai/gpt-oss-120b, openai/gpt-oss-20b, qwen/qwen3.6-27b, llama-3.1-8b-instant
# GROQ_MODEL=openai/gpt-oss-120b
